# ═══════════════════════════════════════════════════════════
#  RUSTY-POLY-SNIPER — Configuration
# ═══════════════════════════════════════════════════════════

# ── MODE D'EXÉCUTION ────────────────────────────────────────
#   dry-run     → simulation (aucun ordre réel)
#   market      → trading réel avec TP/SL + ordre limite GTC au TP
#   no-tp-no-sl → entry uniquement, pas de gestion TP/SL
EXECUTION_MODE=dry-run

# ── CREDENTIALS POLYMARKET ──────────────────────────────────
#   Requis uniquement pour EXECUTION_MODE=market ou no-tp-no-sl
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_FUNDER=0x...          # Adresse proxy/safe (si applicable)
# POLYMARKET_SIGNATURE_TYPE=1      # 0=EOA  1=POLY_PROXY  2=GNOSIS_SAFE

# ── MARCHÉ ──────────────────────────────────────────────────
POLYMARKET_SLUG_PREFIX=btc-updown-5m   # btc / eth / sol / xrp / bnb / doge...
INTERVAL=5m                            # 5m, 15m, 1h, 1d

# ── ENTRÉE ──────────────────────────────────────────────────
ENTRY_THRESHOLD=0.80    # Acheter quand prix token >= seuil  (0.80 = 80¢)
REVERSE_ENTRY=false     # true → signal UP achète DOWN (et vice-versa)

# ── TAKE PROFIT ─────────────────────────────────────────────
TP_DISABLED=false       # true → pas de TP, position tient jusqu'à expiration du marché

#   Si TP_DISABLED=false, choisir l'une des deux options (TP_PRICE a la priorité) :
# TP_PRICE=0.98         # Prix TP fixe absolu (ex: 0.98 = 98¢)
# TP_OFFSET_CENTS=5     # OU : offset depuis le fill price   (ex: 5 = +5¢)
#
#   Un ordre limite GTC est placé automatiquement au TP
#   si la position dépasse 5 shares. Sinon, monitoring prix uniquement.

# ── STOP LOSS ───────────────────────────────────────────────
#   Choisir l'une des deux options (SL_PRICE a la priorité) :
SL_PRICE=0.60           # Prix SL fixe absolu (ex: 0.60 = 60¢)
# SL_OFFSET_CENTS=20    # OU : offset depuis le fill price   (ex: 20 = -20¢)

# ── TAILLE DE POSITION ──────────────────────────────────────
#   Choisir l'une des deux options (ne pas définir les deux) :
TRADE_AMOUNT_USDC=5.0   # Montant fixe par trade en USDC
# TRADE_AMOUNT_PCT=5.0  # OU : % du solde USDC par trade (minimum 1$)

# ── FILTRES TEMPORELS ───────────────────────────────────────
EXCLUDED_DAYS=sat,sun   # Jours sans trading  (mon tue wed thu fri sat sun)
EXCLUDED_HOURS=         # Plages UTC exclues  (ex: 00h-06h  ou  00h-06h,22h-24h)

# ── GESTION DE CAPITAL (Martingale) ─────────────────────────
#   Activer l'un ou l'autre, pas les deux.
MARTINGALE_MULTIPLIER=1.0        # Multiplie la mise après un LOSS  (1.0 = off)
ANTI_MARTINGALE_MULTIPLIER=1.0   # Multiplie la mise après un WIN   (1.0 = off)
ANTI_MARTINGALE_MAX_STREAK=4     # Nombre max de WIN consécutifs avant reset
MARTINGALE_MAX_AMOUNT=0.0        # Plafond USDC pour la mise  (0 = illimité)

# ── PING-PONG INTRA-MARCHÉ ──────────────────────────────────
#   Entre sur l'autre côté après le premier fill, avec multiplicateur.
INMARKET_MULTIPLIER=1.0    # 1.0 = désactivé (1 position max par marché)
INMARKET_MAX_ENTRIES=0     # Nombre max d'entrées ping-pong  (0 = illimité)

# ── LIMITE DE TRADES ────────────────────────────────────────
MARKET_MAX_TRADES=0        # Max trades par marché en mode market  (0 = illimité)

# ── REVERSAL ────────────────────────────────────────────────
#   Après le ping-pong, si le dernier côté redescend sous ce seuil → ouvre l'opposé.
REVERSAL_THRESHOLD=0.0     # 0 = désactivé
REVERSAL_AMOUNT=0.0        # Montant USDC du trade reversal

# ── LOGS ────────────────────────────────────────────────────
LOGS_DIR=logs
