# Mode d'exécution : dry-run (simulation), market (réel avec TP/SL), no-tp-no-sl (entry only)
EXECUTION_MODE=dry-run

# Préfixe slug Polymarket (ex: btc-updown-5m, eth-updown-5m)
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Intervalle du marché (5m, 15m, 1h, etc.)
INTERVAL=5m

# Seuil d'entrée : acheter quand le prix du token >= ce seuil (en décimal, ex: 0.80 = 80¢)
ENTRY_THRESHOLD=0.80

# Offset Take Profit en cents (ex: 5 = +5¢ depuis le fill price)
TP_OFFSET_CENTS=5

# Offset Stop Loss en cents (ex: 20 = -20¢ depuis le fill price)
SL_OFFSET_CENTS=20

# Montant fixe par trade en USDC
TRADE_AMOUNT_USDC=1.0

# Martingale : augmente la mise après un LOSS (1.0 = désactivé)
MARTINGALE_MULTIPLIER=1.0

# Anti-Martingale : augmente la mise après un WIN (1.0 = désactivé)
# Ne peut pas être activé en même temps que MARTINGALE_MULTIPLIER
ANTI_MARTINGALE_MULTIPLIER=1.0
ANTI_MARTINGALE_MAX_STREAK=4

# Plafond montant Martingale/Anti-Martingale en USDC (0 = pas de plafond)
MARTINGALE_MAX_AMOUNT=0.0

# Multiplicateur intra-marché ping-pong (1.0 = désactivé, 1 position max par côté)
INMARKET_MULTIPLIER=1.0
# Nombre max d'entrées ping-pong par marché (0 = illimité)
INMARKET_MAX_ENTRIES=0

# Nombre max de trades par marché en mode market (0 = illimité)
MARKET_MAX_TRADES=0

# Jours exclus du trading, séparés par virgule (ex: sat,sun). Vide = pas de filtre.
# Valeurs : mon,tue,wed,thu,fri,sat,sun
EXCLUDED_DAYS=

# Reversal : si le dernier côté entré redescend à ce prix, on ouvre sur l'opposé (0 = désactivé)
REVERSAL_THRESHOLD=0.0
# Montant du trade reversal en USDC (0 = désactivé)
REVERSAL_AMOUNT=0.0

# Clé privée EVM (hex, avec ou sans 0x). Requis pour mode market.
# POLYMARKET_PRIVATE_KEY=0x...

# Optionnel : funder Polymarket (proxy/safe)
# POLYMARKET_FUNDER=0x...
# POLYMARKET_SIGNATURE_TYPE=2

# Répertoire des logs
LOGS_DIR=logs
