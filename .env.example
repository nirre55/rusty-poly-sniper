# Mode d'exécution : dry-run (simulation) ou market (réel) ou NO_TP_NO_SL
EXECUTION_MODE=dry-run

# Préfixe slug Polymarket (ex: btc-updown-5m, eth-updown-5m)
POLYMARKET_SLUG_PREFIX=btc-updown-5m

# Intervalle du marché (5m, 15m, 1h, etc.)
INTERVAL=5m

# Seuil d'entrée : acheter quand le prix du token >= ce seuil (en décimal, ex: 0.80 = 80¢)
ENTRY_THRESHOLD=0.80

# Offset Take Profit en cents (ex: 5 = +5¢ depuis le fill price)
TP_OFFSET_CENTS=5

# Offset Stop Loss en cents (ex: 20 = -20¢ depuis le fill price)
SL_OFFSET_CENTS=20

# Montant fixe par trade en USDC
TRADE_AMOUNT_USDC=1.0

# Martingale (optionnel)
MARTINGALE_MULTIPLIER=1.0
MARTINGALE_MAX_AMOUNT=0.0

# Clé privée EVM (hex, avec ou sans 0x). Requis pour mode market.
# POLYMARKET_PRIVATE_KEY=0x...

# Optionnel : funder Polymarket (proxy/safe)
# POLYMARKET_FUNDER=0x...
# POLYMARKET_SIGNATURE_TYPE=2

# Répertoire des logs
LOGS_DIR=logs
